  transitionUI: {fileID: 0}
  manifestJson: "{\r\n  \"floor_name\": \"The Ashen Gauntlet\",\r\n  \"tileset_id\":
    \"dungeon\",\r\n  \"palette_override\": [\"#8B1A1A\", \"#C05020\", \"#1A0A00\"],\r\n 
    \"environmental_modifier\": \"\",\r\n  \"stage_message\": \"Fire again. Always
    fire. You wrap yourself in it like armour, don't you? The sentinels have noticed.
    They've had time to prepare.\",\r\n  \"enemy_spawns\": [\r\n    { \"enemy_id\":
    \"ranged_sentinel\", \"count\": 4, \"modifiers\": [\"elemental_immune_fire\"]
    },\r\n    { \"enemy_id\": \"fast_skitter\", \"count\": 5, \"modifiers\": [] },\r\n   
    { \"enemy_id\": \"melee_charger\", \"count\": 2, \"modifiers\": [\"berserk\"]
    }\r\n  ],\r\n  \"new_spell\": {\r\n    \"name\": \"Smouldering Wake\",\r\n   
    \"flavor\": \"A trail of embers that lingers where you wish it wouldn't.\",\r\n   
